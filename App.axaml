<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pixellum.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- DesignSystem is now a Style, included below -->
    </Application.Resources>

    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="/Themes/DesignSystem.axaml"/>
    </Application.Styles>

</Application>