<UserControl
    x:Class="Pixellum.Views.ToolsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Pixellum.Controls"
    FontFamily="Segoe UI, Inter, Helvetica Neue, Arial, sans-serif">

    <UserControl.Styles>
        <!-- Tool button base style -->
        <Style Selector="Button.tool-btn">
            <Setter Property="Background" Value="#2e2e2e"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.tool-btn:pointerover">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Foreground" Value="#fff"/>
        </Style>
        <Style Selector="Button.tool-btn.active">
            <Setter Property="Background" Value="#1e3a2a"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>

        <!-- Panel section header -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
        </Style>

        <!-- Slider style -->
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>

        <!-- TextBox style -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="CaretBrush" Value="#4CAF50"/>
            <Setter Property="SelectionBrush" Value="#2a4a2a"/>
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
        </Style>

        <!-- ComboBox style -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#1e1e1e"
            BorderBrush="#2e2e2e"
            BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0">

                <!-- ── App Name / Logo ───────────────────────────────────── -->
                <Border Padding="16,14,16,12"
                        BorderBrush="#2e2e2e"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="PIXELLUM"
                               Foreground="#4CAF50"
                               FontSize="15"
                               FontWeight="Bold"
                               LetterSpacing="3"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- ── Tools ─────────────────────────────────────────────── -->
                <StackPanel Spacing="10" Margin="12,14,12,0">
                    <TextBlock Text="TOOLS" Classes="section-header"/>

                    <UniformGrid Columns="2" HorizontalAlignment="Stretch">
                        <!-- Brush -->
                        <Border Margin="3">
                            <Button x:Name="BrushToolButton"
                                    Classes="tool-btn active"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnBrushToolClicked">
                                <ToolTip.Tip>Brush  [B]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="🖌️" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Brush" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Eraser -->
                        <Border Margin="3">
                            <Button x:Name="EraserToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnEraserToolClicked">
                                <ToolTip.Tip>Eraser  [E]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="🧹" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Eraser" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Eyedropper -->
                        <Border Margin="3">
                            <Button x:Name="EyedropperToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnEyedropperToolClicked">
                                <ToolTip.Tip>Eyedropper  [I]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="💧" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Pick" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Fill -->
                        <Border Margin="3">
                            <Button x:Name="FillToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnFillToolClicked">
                                <ToolTip.Tip>Fill Bucket  [G]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="🪣" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Fill" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Select -->
                        <Border Margin="3">
                            <Button x:Name="SelectToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnSelectToolClicked">
                                <ToolTip.Tip>Selection  [M]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="⬚" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Select" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Move -->
                        <Border Margin="3">
                            <Button x:Name="MoveToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnMoveToolClicked">
                                <ToolTip.Tip>Move  [V]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="✥" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Move" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Shape -->
                        <Border Margin="3">
                            <Button x:Name="ShapeToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnShapeToolClicked">
                                <ToolTip.Tip>Shape  [U]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="■" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Shape" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Text -->
                        <Border Margin="3">
                            <Button x:Name="TextToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnTextToolClicked">
                                <ToolTip.Tip>Text  [T]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="T" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Text" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                        <!-- Gradient -->
                        <Border Margin="3">
                            <Button x:Name="GradientToolButton"
                                    Classes="tool-btn"
                                    Height="58"
                                    HorizontalAlignment="Stretch"
                                    Click="OnGradientToolClicked">
                                <ToolTip.Tip>Gradient  [G]</ToolTip.Tip>
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="🌫️" FontSize="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Gradient" FontSize="10" HorizontalAlignment="Center" Foreground="#aaa"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </UniformGrid>
                </StackPanel>

                <!-- ── Divider ───────────────────────────────────────────── -->
                <Border Margin="12,14,12,0" Height="1" Background="#2e2e2e"/>

                <!-- ── Color ─────────────────────────────────────────────── -->
                <StackPanel Spacing="10" Margin="12,14,12,0">
                    <TextBlock Text="COLOR" Classes="section-header"/>

                    <!-- Color Wheel -->
                    <controls:ColorWheel x:Name="ColorPicker"
                                         Width="170"
                                         Height="170"
                                         HorizontalAlignment="Center"/>

                    <!-- Primary / Secondary swatches -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Secondary (rendered first = behind) -->
                        <Border Grid.Column="1"
                                x:Name="SecondaryColorPreview"
                                Width="36" Height="36"
                                CornerRadius="6"
                                Background="White"
                                BorderBrush="#3a3a3a"
                                BorderThickness="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="4,0,0,0"
                                Cursor="Hand">
                            <ToolTip.Tip>Secondary Color  ·  Click to swap  [X]</ToolTip.Tip>
                        </Border>

                        <!-- Primary (on top, slightly larger) -->
                        <Border Grid.Column="0"
                                x:Name="PrimaryColorPreview"
                                Width="50" Height="50"
                                CornerRadius="8"
                                Background="Black"
                                BorderBrush="#4CAF50"
                                BorderThickness="2"
                                HorizontalAlignment="Right"
                                Margin="0,0,4,0"
                                Cursor="Hand">
                            <ToolTip.Tip>Primary Color  ·  Click to swap  [X]</ToolTip.Tip>
                        </Border>
                    </Grid>

                    <!-- Hex input -->
                    <Grid ColumnDefinitions="Auto,*" Margin="0,6,0,0">
                        <Border Grid.Column="0"
                                Width="28" Height="28"
                                CornerRadius="4"
                                Background="#333"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                            <TextBlock Text="#"
                                       Foreground="#888"
                                       FontFamily="Consolas, monospace"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBox Grid.Column="1"
                                 x:Name="HexColorInput"
                                 Text="000000"
                                 Watermark="RRGGBB"
                                 MaxLength="6"
                                 FontSize="13"
                                 TextChanged="OnHexColorChanged"/>
                    </Grid>

                    <!-- Quick Color Palette -->
                    <StackPanel Spacing="5" Margin="0,8,0,0">
                        <TextBlock Text="SWATCHES" Classes="section-header"/>
                        <UniformGrid x:Name="QuickColorGrid"
                                     Columns="6"
                                     Rows="2"
                                     Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- ── Divider ───────────────────────────────────────────── -->
                <Border Margin="12,14,12,0" Height="1" Background="#2e2e2e"/>

                <!-- ── Canvas Actions ─────────────────────────────────────── -->
                <StackPanel Spacing="8" Margin="12,14,12,16">
                    <TextBlock Text="CANVAS" Classes="section-header"/>

                    <Button Content="🗑  Clear Layer"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Height="34"
                            Padding="10,0"
                            Background="#3a1a1a"
                            Foreground="#f44336"
                            BorderBrush="#5a2020"
                            BorderThickness="1"
                            CornerRadius="6"
                            Cursor="Hand"
                            Click="OnClearCanvasClicked"/>

                    <Button Content="🎨  Fill Layer"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Height="34"
                            Padding="10,0"
                            Background="#2e2e2e"
                            Foreground="#aaa"
                            BorderBrush="#3a3a3a"
                            BorderThickness="1"
                            CornerRadius="6"
                            Cursor="Hand"
                            Click="OnFillCanvasClicked"/>
                </StackPanel>

                <!-- ── Keyboard shortcut hint ─────────────────────────────── -->
                <Border Margin="12,0,12,16"
                        Padding="10,8"
                        Background="#181818"
                        CornerRadius="8"
                        BorderBrush="#2a2a2a"
                        BorderThickness="1">
                    <StackPanel Spacing="3">
                        <TextBlock Text="SHORTCUTS" Classes="section-header" Margin="0,0,0,4"/>
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="B / E / I / G" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Tools" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="[ / ]" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Brush size" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="X" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Swap colors" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+Z / Y" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Undo / Redo" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Space+drag" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Pan canvas" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Scroll wheel" Foreground="#4CAF50" FontSize="11" FontFamily="Consolas, monospace" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Zoom" Foreground="#666" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>