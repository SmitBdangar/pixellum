<UserControl
    x:Class="Pixellum.Views.ToolsPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Pixellum.Controls"
    FontFamily="Inter, Segoe UI, Helvetica Neue, Arial, sans-serif">

    <UserControl.Styles>

        <!-- ════════ TOOL BUTTON ════════════════════════════════════ -->
        <Style Selector="Button.tool-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.tool-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4d4d4d"/>
        </Style>
        <Style Selector="Button.tool-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.tool-btn.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#2980b9"/>
        </Style>
        <Style Selector="Button.tool-btn.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3498db"/>
        </Style>

        <!-- ════════ SEPARATOR ══════════════════════════════════════ -->
        <Style Selector="Rectangle.tool-sep">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="#303030"/>
            <Setter Property="Margin" Value="8,1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- ════════ GROUP LABEL ════════════════════════════════════ -->
        <Style Selector="TextBlock.group-label">
            <Setter Property="FontSize" Value="7.5"/>
            <Setter Property="Foreground" Value="#505050"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

    </UserControl.Styles>

    <Border Background="#383838"
            BorderBrush="#282828"
            BorderThickness="0,0,1,0"
            Width="52">
        <DockPanel>

            <!-- ══ COLOR SWATCHES ══════════════════════════════════ -->
            <Border DockPanel.Dock="Bottom"
                    Background="#383838"
                    BorderBrush="#282828"
                    BorderThickness="0,1,0,0"
                    Padding="0,9,0,9">
                <Grid Width="40" Height="40" HorizontalAlignment="Center">

                    <!-- BG swatch -->
                    <Border x:Name="SecondaryColorPreview"
                            Width="22" Height="22"
                            CornerRadius="2"
                            Background="White"
                            BorderBrush="#5a5a5a"
                            BorderThickness="1.5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Cursor="Hand">
                        <ToolTip.Tip>Background Color · Click to swap [X]</ToolTip.Tip>
                    </Border>

                    <!-- FG swatch -->
                    <Border x:Name="PrimaryColorPreview"
                            Width="26" Height="26"
                            CornerRadius="2"
                            Background="Black"
                            BorderBrush="#aaaaaa"
                            BorderThickness="1.5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Cursor="Hand">
                        <ToolTip.Tip>Foreground Color · Click to swap [X]</ToolTip.Tip>
                    </Border>

                    <!-- Swap arrows -->
                    <Path HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,1,1,0"
                          Stroke="#888888" StrokeThickness="1.2" Fill="Transparent"
                          Data="M0,3 L5,0 L5,2 L9,2 M9,6 L4,9 L4,7 L0,7"
                          Width="10" Height="9" Stretch="Fill"/>

                </Grid>
            </Border>

            <!-- ══ TOOL BUTTONS ════════════════════════════════════ -->
            <ScrollViewer DockPanel.Dock="Top"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="0">

                    <!-- ─── SELECT ──────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="SEL"/>

                    <!-- Move [V] -->
                    <Button x:Name="MoveToolButton" Classes="tool-btn"
                            Click="OnMoveToolClicked" ToolTip.Tip="Move  [V]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Path Fill="#c0c0c0"
                                      Data="M10,1 L12.5,5.5 L11,5.5 L11,9 L14.5,9 L14.5,7.5 L19,10 L14.5,12.5 L14.5,11 L11,11 L11,14.5 L12.5,14.5 L10,19 L7.5,14.5 L9,14.5 L9,11 L5.5,11 L5.5,12.5 L1,10 L5.5,7.5 L5.5,9 L9,9 L9,5.5 L7.5,5.5 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Marquee [M] -->
                    <Button x:Name="SelectToolButton" Classes="tool-btn"
                            Click="OnSelectToolClicked" ToolTip.Tip="Rectangular Marquee  [M]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Rectangle Canvas.Left="1" Canvas.Top="1"
                                           Width="18" Height="18"
                                           Stroke="#c0c0c0" StrokeThickness="1.5"
                                           StrokeDashArray="3.5,2.5"
                                           Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Lasso [L] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Lasso  [L]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Path Stroke="#c0c0c0" StrokeThickness="1.7" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M10,2 C15.5,2 18,5.5 18,9.5 C18,13.5 15,16.5 11,17 C8,17.5 5.5,15.5 5.5,13 C5.5,10.5 7.5,9 9,8.5 C9.5,8.2 9.5,7.5 9.5,6.5 C9.5,4 9.5,2.8 10,2 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── TRANSFORM ────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="TFM"/>

                    <!-- Crop [C] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Crop  [C]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Path Stroke="#c0c0c0" StrokeThickness="2.5" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M4,0 L4,4 L0,4"/>
                                <Path Stroke="#c0c0c0" StrokeThickness="2.5" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M16,20 L16,16 L20,16"/>
                                <Rectangle Canvas.Left="4" Canvas.Top="4"
                                           Width="12" Height="12"
                                           Stroke="#c0c0c0" StrokeThickness="1.3"
                                           Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── PAINT ─────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="DRAW"/>

                    <!-- Brush [B] -->
                    <Button x:Name="BrushToolButton" Classes="tool-btn active"
                            Click="OnBrushToolClicked" ToolTip.Tip="Brush  [B]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Path Stroke="#ffffff" StrokeThickness="2.2" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M16,2 C17.5,3.5 17.5,6.5 15.5,8.5 L7,17 L3,19 L5,15 L13.5,6.5 C14.5,5.5 14,3 14,3"/>
                                <Path Stroke="#ffffff" StrokeThickness="1.8" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M6,15.5 L9.5,12"/>
                                <Ellipse Canvas.Left="2.5" Canvas.Top="17.5"
                                         Width="3" Height="2.5"
                                         Fill="#ffffff"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Pencil -->
                    <Button Classes="tool-btn" ToolTip.Tip="Pencil  [B]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <!-- Body -->
                                <Path Fill="#c0c0c0"
                                      Data="M15,1 L19,5 L7,17 L2,18 L3,13 Z"/>
                                <!-- Cap band -->
                                <Path Fill="#888888"
                                      Data="M17,3 L19,5 L16,8 L14,6 Z"/>
                                <!-- Wood tip (yellow) -->
                                <Path Fill="#c8a050"
                                      Data="M3,13 L7,17 L5,19 L2,18 Z"/>
                                <!-- Tip line -->
                                <Path Stroke="#c0c0c0" StrokeThickness="0.8" Fill="Transparent"
                                      Data="M2,18 L4.5,18"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Eraser [E] -->
                    <Button x:Name="EraserToolButton" Classes="tool-btn"
                            Click="OnEraserToolClicked" ToolTip.Tip="Eraser  [E]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <!-- Pink eraser body -->
                                <Path Fill="#d46060"
                                      Data="M3,12 L9,4 L17,4 L17,12 L11,19 Z"/>
                                <!-- Light face -->
                                <Path Fill="#e88888"
                                      Data="M9,4 L17,4 L17,12 L15,12 L9,12 Z"/>
                                <!-- Mid line -->
                                <Path Stroke="#b04040" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M3,12 L17,12"/>
                                <!-- Base line -->
                                <Path Stroke="#b0b0b0" StrokeThickness="1.5" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M2,19 L18,19"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── RETOUCH ────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="RTCH"/>

                    <!-- Clone Stamp [S] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Clone Stamp  [S]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Ellipse Canvas.Left="1" Canvas.Top="1"
                                         Width="11" Height="11"
                                         Stroke="#c0c0c0" StrokeThickness="1.7"
                                         Fill="Transparent"/>
                                <Line StartPoint="6.5,4" EndPoint="6.5,8"
                                      Stroke="#c0c0c0" StrokeThickness="1.3"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="4.5,6" EndPoint="8.5,6"
                                      Stroke="#c0c0c0" StrokeThickness="1.3"
                                      StrokeLineCap="Round"/>
                                <Path Stroke="#c0c0c0" StrokeThickness="2.2" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M11,11 L17,17"/>
                                <Path Fill="#c0c0c0"
                                      Data="M15,7 L19,7 L19,11 L17.5,9.5 L14.5,12.5 L12.5,10.5 L15.5,7.5 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Healing Brush [J] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Healing Brush  [J]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Ellipse Canvas.Left="1.5" Canvas.Top="1.5"
                                         Width="13" Height="13"
                                         Stroke="#c0c0c0" StrokeThickness="1.8"
                                         Fill="Transparent"/>
                                <Line StartPoint="8,4.5" EndPoint="8,12.5"
                                      Stroke="#c0c0c0" StrokeThickness="1.7"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="4,8" EndPoint="13,8"
                                      Stroke="#c0c0c0" StrokeThickness="1.7"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="14.5,14.5" EndPoint="19,19"
                                      Stroke="#c0c0c0" StrokeThickness="2.5"
                                      StrokeLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── FILL ───────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="FILL"/>

                    <!-- Paint Bucket [G] -->
                    <Button x:Name="FillToolButton" Classes="tool-btn"
                            Click="OnFillToolClicked" ToolTip.Tip="Fill Bucket  [G]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Path Fill="#c0c0c0"
                                      Data="M5,3 L7,1 L15,9 C16.5,10.5 16.5,12.5 15,14 C13.5,15.5 11.5,15.5 10,14 C8.5,12.5 8.5,10.5 10,9 Z"/>
                                <Path Fill="#888888"
                                      Data="M5,3 L7,5 L5,7 L3,5 Z"/>
                                <Line StartPoint="1,18" EndPoint="19,18"
                                      Stroke="#c0c0c0" StrokeThickness="2.5"
                                      StrokeLineCap="Round"/>
                                <Ellipse Canvas.Left="13.5" Canvas.Top="9.5"
                                         Width="5" Height="7"
                                         Fill="#4a9eda"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Gradient [G] -->
                    <Button x:Name="GradientToolButton" Classes="tool-btn"
                            Click="OnGradientToolClicked" ToolTip.Tip="Gradient  [G]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Rectangle Canvas.Left="1" Canvas.Top="6"
                                           Width="18" Height="8"
                                           Fill="#c0c0c0"/>
                                <Path Stroke="#383838" StrokeThickness="1.6" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M2,10 L16,10 M13,8 L16,10 L13,12"/>
                                <!-- gradient side shade -->
                                <Path Fill="#383838" Opacity="0.5"
                                      Data="M1,6 H10 V14 H1 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Eyedropper [I] -->
                    <Button x:Name="EyedropperToolButton" Classes="tool-btn"
                            Click="OnEyedropperToolClicked" ToolTip.Tip="Eyedropper  [I]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <!-- Body -->
                                <Path Fill="#c0c0c0"
                                      Data="M13,2 L18,7 L8,17 L3,12 Z"/>
                                <!-- Scope circle -->
                                <Ellipse Canvas.Left="11.5" Canvas.Top="0.5"
                                         Width="8" Height="8"
                                         Stroke="#aaaaaa" StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <!-- Crosshair in scope -->
                                <Line StartPoint="15.5,1.5" EndPoint="15.5,8"
                                      Stroke="#aaaaaa" StrokeThickness="1"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="12,4.5" EndPoint="19,4.5"
                                      Stroke="#aaaaaa" StrokeThickness="1"
                                      StrokeLineCap="Round"/>
                                <!-- Colored tip -->
                                <Ellipse Canvas.Left="1" Canvas.Top="15"
                                         Width="5" Height="5"
                                         Fill="#4a9eda"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── TYPE ───────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="TYPE"/>

                    <!-- Type [T] -->
                    <Button x:Name="TextToolButton" Classes="tool-btn"
                            Click="OnTextToolClicked" ToolTip.Tip="Horizontal Type  [T]">
                        <Viewbox Width="17" Height="19">
                            <Canvas Width="20" Height="22">
                                <!-- Serif T crossbar + stem -->
                                <Path Fill="#c0c0c0"
                                      Data="M1,2 H19 V5.5 H12 V18 H8 V5.5 H1 Z"/>
                                <!-- Cursor blink line -->
                                <Rectangle Canvas.Left="10" Canvas.Top="19"
                                           Width="1.5" Height="4"
                                           Fill="#4a9eda"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── VECTOR ─────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="VECT"/>

                    <!-- Pen [P] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Pen Tool  [P]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <!-- Nib shape -->
                                <Path Fill="#c0c0c0"
                                      Data="M10,1 L13.5,7 L10,19 L6.5,7 Z"/>
                                <!-- Shoulder arc -->
                                <Path Stroke="#c0c0c0" StrokeThickness="1.4" Fill="Transparent"
                                      StrokeLineCap="Round"
                                      Data="M6.5,7 C6.5,4.5 8,3 10,3 C12,3 13.5,4.5 13.5,7"/>
                                <!-- Anchor diamond at tip -->
                                <Path Fill="#4a9eda"
                                      Data="M10,17 L12,19 L10,21 L8,19 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Shape [U] -->
                    <Button x:Name="ShapeToolButton" Classes="tool-btn"
                            Click="OnShapeToolClicked" ToolTip.Tip="Rectangle Shape  [U]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Rectangle Canvas.Left="1.5" Canvas.Top="3"
                                           Width="17" Height="14"
                                           Stroke="#c0c0c0" StrokeThickness="2"
                                           Fill="Transparent"/>
                                <!-- Anchor points (corners) -->
                                <Rectangle Canvas.Left="0" Canvas.Top="1.5" Width="3" Height="3" Fill="#4a9eda"/>
                                <Rectangle Canvas.Left="17" Canvas.Top="1.5" Width="3" Height="3" Fill="#4a9eda"/>
                                <Rectangle Canvas.Left="0" Canvas.Top="15.5" Width="3" Height="3" Fill="#4a9eda"/>
                                <Rectangle Canvas.Left="17" Canvas.Top="15.5" Width="3" Height="3" Fill="#4a9eda"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Rectangle Classes="tool-sep"/>

                    <!-- ─── VIEW ───────────────────────────────────── -->
                    <TextBlock Classes="group-label" Text="VIEW"/>

                    <!-- Zoom [Z] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Zoom  [Z]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <Ellipse Canvas.Left="1" Canvas.Top="1"
                                         Width="13" Height="13"
                                         Stroke="#c0c0c0" StrokeThickness="2"
                                         Fill="Transparent"/>
                                <Line StartPoint="7.5,5" EndPoint="7.5,10.5"
                                      Stroke="#c0c0c0" StrokeThickness="1.8"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="4.5,7.5" EndPoint="10.5,7.5"
                                      Stroke="#c0c0c0" StrokeThickness="1.8"
                                      StrokeLineCap="Round"/>
                                <Line StartPoint="12.5,12.5" EndPoint="19,19"
                                      Stroke="#c0c0c0" StrokeThickness="2.8"
                                      StrokeLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Hand [H] -->
                    <Button Classes="tool-btn" ToolTip.Tip="Hand (Pan)  [H]">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="20" Height="20">
                                <!-- 4 finger tops (rounded rects via Path) -->
                                <Path Fill="#c0c0c0"
                                      Data="M5.5,9 L5.5,3.5 C5.5,2.7 6.2,2 7,2 C7.8,2 8.5,2.7 8.5,3.5 L8.5,9
                                            M9,9 L9,2.5 C9,1.7 9.7,1 10.5,1 C11.3,1 12,1.7 12,2.5 L12,9
                                            M12.5,9 L12.5,3.5 C12.5,2.7 13.2,2 14,2 C14.8,2 15.5,2.7 15.5,3.5 L15.5,9
                                            M16,9 L16,5.5 C16,4.7 16.7,4 17.5,4 C18.3,4 19,4.7 19,5.5 L19,12 C19,15.5 16.5,18 13,18 L7,18 C4.5,18 3,16.5 3,14.5 L3,11.5 C3,10.7 3.7,10 4.5,10 C5.3,10 5.5,10.7 5.5,11 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- bottom padding -->
                    <Border Height="6"/>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>