<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pixellum.Views.AdjustmentsPanel"
             Background="{StaticResource PanelBgBrush}"
             FontFamily="Inter, Segoe UI, Helvetica Neue, Arial, sans-serif">

    <UserControl.Styles>
        
        <Style Selector="Button.adj-btn">
            <Setter Property="Background" Value="{StaticResource AppBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.adj-btn:pointerover">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        
        <Style Selector="Button.adj-btn Path">
            <Setter Property="Fill" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.adj-btn:pointerover Path">
            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style Selector="TextBlock.adj-label">
            <Setter Property="FontSize" Value="8.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="16" Margin="12,16">
        <TextBlock Text="IMAGE ADJUSTMENTS"
                   Foreground="{StaticResource TextDimBrush}"
                   FontSize="10"
                   FontWeight="Bold"
                   LetterSpacing="1.5"/>

        <UniformGrid Columns="4">
            <!-- Brightness / Contrast -->
            <StackPanel Margin="2">
                <Button x:Name="BrightnessContrastBtn" Classes="adj-btn" Click="OnBrightnessContrastClicked" ToolTip.Tip="Brightness / Contrast">
                    <Path Data="M10,2 A8,8 0 1,0 10,18 A8,8 0 1,0 10,2 M10,4 V16 A6,6 0 1,1 10,4"/>
                </Button>
                <TextBlock Text="BRIGHT" Classes="adj-label"/>
            </StackPanel>

            <!-- Levels -->
            <StackPanel Margin="2">
                <Button x:Name="LevelsBtn" Classes="adj-btn" Click="OnLevelsClicked" ToolTip.Tip="Levels">
                    <Path Data="M2,16 H18 V18 H2 Z M4,14 H6 V10 H4 Z M9,14 H11 V4 H9 Z M14,14 H16 V8 H14 Z"/>
                </Button>
                <TextBlock Text="LEVELS" Classes="adj-label"/>
            </StackPanel>

            <!-- Curves -->
            <StackPanel Margin="2">
                <Button x:Name="CurvesBtn" Classes="adj-btn" Click="OnCurvesClicked" ToolTip.Tip="Curves">
                    <Path Data="M2,18 C2,18 6,14 10,10 C14,6 18,2 18,2" Stroke="{StaticResource TextDimBrush}" StrokeThickness="2" Fill="Transparent"/>
                </Button>
                <TextBlock Text="CURVES" Classes="adj-label"/>
            </StackPanel>

            <!-- Hue / Saturation -->
            <StackPanel Margin="2">
                <Button x:Name="HueSatBtn" Classes="adj-btn" Click="OnHueSaturationClicked" ToolTip.Tip="Hue / Saturation">
                    <Path Data="M10,2 L18,10 L10,18 L2,10 Z"/>
                </Button>
                <TextBlock Text="HUE" Classes="adj-label"/>
            </StackPanel>

            <!-- Color Balance -->
            <StackPanel Margin="2">
                <Button x:Name="ColorBalanceBtn" Classes="adj-btn" Click="OnColorBalanceClicked" ToolTip.Tip="Color Balance">
                    <Path Data="M12,2 L12,6 M12,18 L12,22 M2,12 L6,12 M18,12 L22,12 M5,5 L8,8 M16,16 L19,19 M5,19 L8,16 M16,8 L19,5" Stroke="{StaticResource TextDimBrush}" StrokeThickness="2"/>
                </Button>
                <TextBlock Text="BAL" Classes="adj-label"/>
            </StackPanel>

            <!-- Exposure -->
            <StackPanel Margin="2">
                <Button x:Name="ExposureBtn" Classes="adj-btn" Click="OnExposureClicked" ToolTip.Tip="Exposure">
                    <Path Data="M12,7 A5,5 0 1,0 12,17 A5,5 0 1,0 12,7 M12,2 V5 M12,19 V22 M2,12 H5 M19,12 H22 M4.9,4.9 L7,7 M17,17 L19.1,19.1 M4.9,19.1 L7,17 M17,7 L19.1,4.9" Stroke="{StaticResource TextDimBrush}" StrokeThickness="1.5"/>
                </Button>
                <TextBlock Text="EXP" Classes="adj-label"/>
            </StackPanel>

            <!-- Invert -->
            <StackPanel Margin="2">
                <Button x:Name="InvertBtn" Classes="adj-btn" Click="OnInvertClicked" ToolTip.Tip="Invert">
                    <Path Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 1,0 12,2 M12,4 V20 A8,8 0 1,1 12,4"/>
                </Button>
                <TextBlock Text="INV" Classes="adj-label"/>
            </StackPanel>

            <!-- Add more as needed -->
        </UniformGrid>
    </StackPanel>
</UserControl>
