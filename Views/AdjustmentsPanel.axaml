<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pixellum.Views.AdjustmentsPanel"
             Background="#161616"
             FontFamily="Inter, Segoe UI, Helvetica Neue, Arial, sans-serif">

    <UserControl.Styles>
        <Style Selector="Button.adj-btn">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="BorderBrush" Value="#252525"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.adj-btn /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.adj-btn:pointerover /template/ ContentPresenter">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>
        <Style Selector="Button.adj-btn:pointerover">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#31A8FF"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <Style Selector="Button.adj-btn:pressed">
            <Setter Property="Background" Value="#0d1f30"/>
        </Style>
        <Style Selector="TextBlock.adj-label">
            <Setter Property="FontSize" Value="8.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="#4a4a4a"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="10" Margin="10,12,10,14">

        <TextBlock Text="IMAGE ADJUSTMENTS"
                   Foreground="#3a3a3a"
                   FontSize="9"
                   FontWeight="SemiBold"
                   LetterSpacing="2"/>

        <UniformGrid Columns="4" HorizontalAlignment="Stretch">

            <!-- Brightness / Contrast -->
            <Border Margin="3">
                <Button x:Name="BrightnessContrastBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnBrightnessContrastClicked" ToolTip.Tip="Brightness / Contrast">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="☀" FontSize="20" HorizontalAlignment="Center" Foreground="#e8c84a"/>
                        <TextBlock Text="B / C" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Levels -->
            <Border Margin="3">
                <Button x:Name="LevelsBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnLevelsClicked" ToolTip.Tip="Levels">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="▊" FontSize="20" HorizontalAlignment="Center" Foreground="#5ab87a"/>
                        <TextBlock Text="Levels" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Curves -->
            <Border Margin="3">
                <Button x:Name="CurvesBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnCurvesClicked" ToolTip.Tip="Curves">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="∿" FontSize="22" HorizontalAlignment="Center" Foreground="#5a90d8"/>
                        <TextBlock Text="Curves" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Hue / Saturation -->
            <Border Margin="3">
                <Button x:Name="HueSatBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnHueSaturationClicked" ToolTip.Tip="Hue / Saturation">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="🎨" FontSize="19" HorizontalAlignment="Center"/>
                        <TextBlock Text="Hue/Sat" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Color Balance -->
            <Border Margin="3">
                <Button x:Name="ColorBalanceBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnColorBalanceClicked" ToolTip.Tip="Color Balance">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="⚖" FontSize="20" HorizontalAlignment="Center" Foreground="#a87ad8"/>
                        <TextBlock Text="Balance" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Vibrance -->
            <Border Margin="3">
                <Button x:Name="VibranceBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnVibranceClicked" ToolTip.Tip="Vibrance / Saturation">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="✦" FontSize="20" HorizontalAlignment="Center" Foreground="#e08060"/>
                        <TextBlock Text="Vibrance" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Exposure -->
            <Border Margin="3">
                <Button x:Name="ExposureBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnExposureClicked" ToolTip.Tip="Exposure">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="◎" FontSize="20" HorizontalAlignment="Center" Foreground="#e0d060"/>
                        <TextBlock Text="Exposure" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Invert -->
            <Border Margin="3">
                <Button x:Name="InvertBtn" Classes="adj-btn"
                        Width="54" Height="56" HorizontalAlignment="Center"
                        Click="OnInvertClicked" ToolTip.Tip="Invert Colors  Ctrl+I">
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock Text="⬛" FontSize="20" HorizontalAlignment="Center" Foreground="#6090d8"/>
                        <TextBlock Text="Invert" Classes="adj-label"/>
                    </StackPanel>
                </Button>
            </Border>

        </UniformGrid>
    </StackPanel>

</UserControl>
