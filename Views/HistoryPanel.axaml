<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Pixellum.Core"
             x:Class="Pixellum.Views.HistoryPanel"
             Background="#252525"
             BorderBrush="#333"
             BorderThickness="0,1,0,0">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2a2a2a"
                BorderBrush="#333"
                BorderThickness="0,0,0,1"
                Padding="12,10">
            <TextBlock Text="HISTORY"
                       Foreground="#e0e0e0"
                       FontWeight="SemiBold"
                       FontSize="13"
                       LetterSpacing="1"/>
        </Border>

        <!-- History List -->
        <ListBox Grid.Row="1"
                 x:Name="HistoryListBox"
                 Background="Transparent"
                 SelectionChanged="OnHistorySelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="core:HistoryStep">
                    <Grid ColumnDefinitions="Auto,*" Margin="4,2">
                        <TextBlock Grid.Column="0" Text="• " Foreground="#555" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding ActionName}" Foreground="#ccc"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
