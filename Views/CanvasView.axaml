<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pixellum.Views.CanvasView">
    
    <Grid Background="#1e1e1e" 
          HorizontalAlignment="Stretch" 
          VerticalAlignment="Stretch"
          Name="CanvasGrid"
          ClipToBounds="True">
        
        <Grid Name="TransformContainer"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                    <TranslateTransform X="0" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Image Name="CanvasImage"
                   Stretch="None"
                   RenderOptions.BitmapInterpolationMode="None"/>
            
            <Canvas Name="OverlayCanvas" Background="{x:Null}">
                <Rectangle Name="SelectionMarquee"
                           Stroke="#90ffffff"
                           StrokeThickness="1"
                           StrokeDashArray="4,4"
                           IsVisible="False" />
                <Rectangle Name="SelectionMarqueeInner"
                           Stroke="White"
                           StrokeThickness="1"
                           StrokeDashArray="4,4"
                           StrokeDashOffset="4"
                           IsVisible="False" />
                <Rectangle Name="ShapePreview"
                           IsVisible="False"
                           IsHitTestVisible="False" />
                <Ellipse Name="BrushPreview"
                         IsVisible="False"
                         IsHitTestVisible="False"
                         Stroke="DarkGray"
                         StrokeThickness="1" />
                <TextBox Name="TextOverlayBox"
                         IsVisible="False"
                         Background="#44000000"
                         Foreground="White"
                         BorderThickness="1"
                         BorderBrush="#4CAF50"
                         CornerRadius="2"
                         Padding="4,3"
                         AcceptsReturn="True"
                         FontSize="24"/>
                <Rectangle Name="GridOverlayRect"
                           IsVisible="False"
                           IsHitTestVisible="False" />
            </Canvas>
        </Grid>
    </Grid>
</UserControl>