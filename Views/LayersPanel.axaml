<UserControl
    x:Class="Pixellum.Views.LayersPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FontFamily="Segoe UI, Inter, Helvetica Neue, Arial, sans-serif">

    <UserControl.Styles>
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#4CAF50"/>
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
        </Style>
        <Style Selector="TextBlock.prop-label">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.icon-btn">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleButton.icon-btn:pointerover">
            <Setter Property="Background" Value="#363636"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.icon-btn:checked">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2e5e3e"/>
        </Style>
        <Style Selector="Button.add-btn">
            <Setter Property="Background" Value="#1b3324"/>
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="BorderBrush" Value="#2e5e3e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.add-btn:pointerover">
            <Setter Property="Background" Value="#264a34"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#1a1a1a"
            BorderBrush="#2a2a2a"
            BorderThickness="1,0,0,0">
        <DockPanel>

            <!-- ── Header ─────────────────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Padding="12,10"
                    BorderBrush="#2a2a2a"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="LAYERS"
                               Classes="section-header"
                               VerticalAlignment="Center"/>

                    <!-- Merge down -->
                    <Button Grid.Column="1"
                            x:Name="MergeDownButton"
                            Classes="icon-btn"
                            Content="⬇"
                            FontSize="13"
                            Width="26" Height="26"
                            Margin="0,0,4,0"
                            Click="OnMergeDownClicked"
                            ToolTip.Tip="Merge with layer below"/>

                    <!-- Duplicate -->
                    <Button Grid.Column="2"
                            x:Name="DuplicateLayerButton"
                            Classes="icon-btn"
                            Content="⎘"
                            FontSize="13"
                            Width="26" Height="26"
                            Margin="0,0,4,0"
                            Click="OnDuplicateLayerClicked"
                            ToolTip.Tip="Duplicate active layer"/>

                    <!-- Add -->
                    <Button Grid.Column="3"
                            x:Name="AddLayerButton"
                            Classes="add-btn"
                            Content="+"
                            FontSize="17"
                            FontWeight="Bold"
                            Width="26" Height="26"
                            Click="OnAddLayerClicked"
                            ToolTip.Tip="Add new layer  [+]"/>

                    <!-- Add Fill -->
                    <Button Grid.Column="4"
                            x:Name="AddFillLayerButton"
                            Classes="icon-btn"
                            Content="⬛"
                            FontSize="13"
                            Width="26" Height="26"
                            Margin="4,0,0,0"
                            Click="OnAddFillLayerClicked"
                            ToolTip.Tip="Add Solid Color Fill Layer"/>
                </Grid>
            </Border>

            <!-- ── Active Layer Info ───────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Background="#181818"
                    Padding="12,10"
                    BorderBrush="#2a2a2a"
                    BorderThickness="0,0,0,1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ActiveLayerName"
                               Text="Layer 1"
                               Foreground="#e0e0e0"
                               FontSize="13"
                               FontWeight="SemiBold"/>

                    <!-- Opacity row -->
                    <Grid ColumnDefinitions="52,*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="Opacity"
                                   Classes="prop-label"
                                   Margin="0,0,8,0"/>
                        <Slider Grid.Column="1"
                                x:Name="LayerOpacitySlider"
                                Minimum="0" Maximum="100" Value="100"
                                VerticalAlignment="Center"
                                ValueChanged="OnLayerOpacityChanged"/>
                        <TextBlock Grid.Column="2"
                                   x:Name="OpacityValueText"
                                   Text="100%"
                                   Foreground="#888"
                                   FontSize="11"
                                   FontFamily="Consolas, monospace"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   MinWidth="36"/>
                    </Grid>

                    <!-- Blend mode row -->
                    <Grid ColumnDefinitions="52,*">
                        <TextBlock Grid.Column="0"
                                   Text="Mode"
                                   Classes="prop-label"
                                   Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="BlendModeComboBox"
                                  SelectionChanged="OnBlendModeChanged">
                            <ComboBoxItem Content="Normal"      IsSelected="True"/>
                            <ComboBoxItem Content="Darken"/>
                            <ComboBoxItem Content="Multiply"/>
                            <ComboBoxItem Content="ColorBurn"/>
                            <ComboBoxItem Content="Lighten"/>
                            <ComboBoxItem Content="Screen"/>
                            <ComboBoxItem Content="ColorDodge"/>
                            <ComboBoxItem Content="Overlay"/>
                            <ComboBoxItem Content="SoftLight"/>
                            <ComboBoxItem Content="HardLight"/>
                            <ComboBoxItem Content="Difference"/>
                            <ComboBoxItem Content="Exclusion"/>
                            <ComboBoxItem Content="Hue"/>
                            <ComboBoxItem Content="Saturation"/>
                            <ComboBoxItem Content="Color"/>
                            <ComboBoxItem Content="Luminosity"/>
                        </ComboBox>
                    </Grid>

                    <!-- Locks and Clipping Mask -->
                    <Grid ColumnDefinitions="52,*,Auto,Auto,Auto,Auto" Margin="0,2,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="Locks"
                                   Classes="prop-label"
                                   Margin="0,0,8,0"/>
                        <ToggleButton Grid.Column="2" x:Name="LockTransToggle" Content="▤" Classes="icon-btn" Width="24" Height="24" Margin="2,0" ToolTip.Tip="Lock Transparency" Click="OnLockToggled"/>
                        <ToggleButton Grid.Column="3" x:Name="LockPixToggle"   Content="🖌" Classes="icon-btn" Width="24" Height="24" Margin="2,0" ToolTip.Tip="Lock Image Pixels" Click="OnLockToggled"/>
                        <ToggleButton Grid.Column="4" x:Name="LockPosToggle"   Content="✥" Classes="icon-btn" Width="24" Height="24" Margin="2,0" ToolTip.Tip="Lock Position"     Click="OnLockToggled"/>
                        <ToggleButton Grid.Column="5" x:Name="ClipMaskToggle"  Content="◧" Classes="icon-btn" Width="24" Height="24" Margin="10,0,0,0" ToolTip.Tip="Clipping Mask" Click="OnLockToggled"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Layers List ─────────────────────────────────────────── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8">
                <StackPanel x:Name="LayersStack" Spacing="4"/>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>