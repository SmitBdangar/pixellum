<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Pixellum.Views"
        x:Class="Pixellum.MainWindow"
        Title="Pixellum"
        Width="1400" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a"
        FontFamily="Segoe UI, Inter, Helvetica Neue, Arial, sans-serif">

    <Window.Styles>
        <Style Selector="Menu">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
        <Style Selector="MenuItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="#4a4a4a"/>
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ── Menu Bar ─────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#252525" BorderBrush="#333" BorderThickness="0,0,0,1">
            <Menu Background="Transparent" Padding="4,0">

                <!-- File -->
                <MenuItem Header="_File">
                    <MenuItem Header="_New…"            Click="OnNewClicked"          InputGesture="Ctrl+N"/>
                    <MenuItem Header="_Open Image…"     Click="OnOpenClicked"         InputGesture="Ctrl+O"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="_Save"            Click="OnSaveClicked"         InputGesture="Ctrl+S"/>
                    <MenuItem Header="Save _As…"        Click="OnSaveAsClicked"       InputGesture="Ctrl+Shift+S"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="Export _PNG…"     Click="OnExportPngClicked"    InputGesture="Ctrl+E"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="_Close"           Click="OnCloseDocClicked"/>
                </MenuItem>

                <!-- Edit -->
                <MenuItem Header="_Edit">
                    <MenuItem Header="_Undo"  Click="OnUndoClicked" InputGesture="Ctrl+Z"/>
                    <MenuItem Header="_Redo"  Click="OnRedoClicked" InputGesture="Ctrl+Y"/>
                </MenuItem>

                <!-- Image -->
                <MenuItem Header="_Image">
                    <MenuItem Header="Canvas _Size…"       Click="OnCanvasSizeClicked"/>
                    <MenuItem Header="_Image Size…"        Click="OnImageSizeClicked"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="_Adjustments">
                        <MenuItem Header="Brightness / _Contrast…"  Click="OnBrightnessContrastClicked"/>
                        <MenuItem Header="_Hue / Saturation…"       Click="OnHueSaturationClicked"/>
                        <MenuItem Header="_Levels…"                 Click="OnLevelsClicked"/>
                        <MenuItem Header="C_urves…"                 Click="OnCurvesClicked"/>
                        <MenuItem Header="Color _Balance…"          Click="OnColorBalanceClicked"/>
                    </MenuItem>
                    <Separator Background="#444"/>
                    <MenuItem Header="Rotate Canvas">
                        <MenuItem Header="90° Clockwise"       Click="OnRotate90CWClicked"/>
                        <MenuItem Header="90° Counter-Clockwise" Click="OnRotate90CCWClicked"/>
                        <MenuItem Header="180°"                Click="OnRotate180Clicked"/>
                    </MenuItem>
                    <MenuItem Header="Flip Canvas">
                        <MenuItem Header="Flip _Horizontal"   Click="OnFlipHClicked"/>
                        <MenuItem Header="Flip _Vertical"     Click="OnFlipVClicked"/>
                    </MenuItem>
                </MenuItem>

                <!-- View -->
                <MenuItem Header="_View">
                    <MenuItem Header="Zoom _In"    Click="OnZoomInClicked"    InputGesture="Ctrl+OemPlus"/>
                    <MenuItem Header="Zoom _Out"   Click="OnZoomOutClicked"   InputGesture="Ctrl+OemMinus"/>
                    <MenuItem Header="_Reset Zoom" Click="OnZoomResetClicked" InputGesture="Ctrl+D0"/>
                    <Separator Background="#444"/>
                    <MenuItem Header="Toggle _Grid"    Click="OnToggleGridClicked"    InputGesture="Ctrl+G"/>
                </MenuItem>

            </Menu>
        </Border>

        <!-- ── Status Bar ───────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="#1e1e1e"
                BorderBrush="#333"
                BorderThickness="0,1,0,0"
                Padding="14,5">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="#aaa"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="CursorPosText"
                           Grid.Column="1"
                           Text="—"
                           Foreground="#666"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="CanvasSizeText"
                           Grid.Column="2"
                           Text="800 × 600"
                           Foreground="#666"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="ActiveToolText"
                           Grid.Column="3"
                           Text="Tool: Brush"
                           Foreground="#888"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
                <TextBlock x:Name="ZoomText"
                           Grid.Column="4"
                           Text="100%"
                           Foreground="#888"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Main Panel ───────────────────────────────────────────────────── -->
        <Grid ColumnDefinitions="240,*,220">

            <views:ToolsPanel Grid.Column="0" x:Name="ToolsPanelControl"/>

            <Border Grid.Column="1"
                    Background="#2b2b2b"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                          Margin="30">
                        <!-- Checkerboard background to indicate transparency -->
                        <Border x:Name="CanvasCheckerBg"
                                Background="Transparent">
                            <Border.Background>
                                <DrawingBrush TileMode="Tile"
                                              SourceRect="0,0,16,16"
                                              DestinationRect="0,0,16,16">
                                    <DrawingBrush.Drawing>
                                        <DrawingGroup>
                                            <GeometryDrawing Brush="#404040">
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,16,16"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <GeometryDrawing Brush="#4a4a4a">
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <RectangleGeometry Rect="0,0,8,8"/>
                                                        <RectangleGeometry Rect="8,8,8,8"/>
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingGroup>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Border.Background>
                        </Border>
                        <Border BoxShadow="0 8 32 8 #AA000000"
                                CornerRadius="2"
                                Background="Transparent">
                            <views:CanvasView x:Name="MainCanvasView"/>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>

            <views:LayersPanel Grid.Column="2" x:Name="LayersPanelControl"/>

        </Grid>

    </DockPanel>
</Window>