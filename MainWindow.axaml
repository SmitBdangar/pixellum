<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Pixellum.Views"
        x:Class="Pixellum.MainWindow"
        Title="Pixellum"
        Width="1440" Height="900"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e"
        FontFamily="Inter, Segoe UI, Helvetica Neue, Arial, sans-serif">

    <Window.Styles>
        <!-- Import Global Styles (now handled in App.axaml, but keeping for design-time if needed) -->

        <!-- ══ MENU ═════════════════════════════════════════════════ -->
        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="TextElement.Foreground" Value="#ffffff"/>
        </Style>
        <Style Selector="MenuItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="TextElement.Foreground" Value="#ffffff"/>
        </Style>

        <!-- ══ TOOLBAR BUTTONS ══════════════════════════════════════ -->
        <Style Selector="Button.tb">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.tb:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3c3c3c"/>
            <Setter Property="TextElement.Foreground" Value="#fff"/>
        </Style>

        <!-- ══ STATUS ═══════════════════════════════════════════════ -->
        <Style Selector="TextBlock.status">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
        </Style>

        <!-- ══ SPLITTERS ════════════════════════════════════════════ -->
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Width" Value="2"/>
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        </Style>

        <!-- ══ PANEL SECTION HEADERS ════════════════════════════════ -->
        <Style Selector="Border.panel-section-header">
            <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>

    </Window.Styles>

    <DockPanel Background="{StaticResource AppBgBrush}">

        <!-- ═══════════════════════════════════════════════════════════
             TITLE BAR + MENU
             ═══════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="36">
            <Grid ColumnDefinitions="Auto,*">
                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0"
                            VerticalAlignment="Center" Margin="12,0,12,0">
                    <Border Background="{StaticResource AccentBrush}" Width="20" Height="20" CornerRadius="4"
                            VerticalAlignment="Center" Margin="0,0,10,0" BoxShadow="0 2 4 0 #40000000">
                        <TextBlock Text="Px" FontSize="10" FontWeight="Black" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PIXELLUM" FontSize="11" Foreground="#ffffff"
                               LetterSpacing="1.5" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menu -->
                <Menu Grid.Column="1" Background="Transparent" Padding="6,0" VerticalAlignment="Center">
                    <MenuItem Header="_File">
                        <MenuItem Header="_New…"          Click="OnNewClicked"       InputGesture="Ctrl+N"/>
                        <MenuItem Header="_Open Image…"   Click="OnOpenClicked"      InputGesture="Ctrl+O"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="_Save"          Click="OnSaveClicked"      InputGesture="Ctrl+S"/>
                        <MenuItem Header="Save _As…"      Click="OnSaveAsClicked"    InputGesture="Ctrl+Shift+S"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="Export _PNG…"   Click="OnExportPngClicked" InputGesture="Ctrl+E"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="_Close"         Click="OnCloseDocClicked"/>
                    </MenuItem>
                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo" Click="OnUndoClicked" InputGesture="Ctrl+Z"/>
                        <MenuItem Header="_Redo" Click="OnRedoClicked" InputGesture="Ctrl+Y"/>
                    </MenuItem>
                    <MenuItem Header="_Image">
                        <MenuItem Header="Canvas _Size…"  Click="OnCanvasSizeClicked"/>
                        <MenuItem Header="_Image Size…"   Click="OnImageSizeClicked"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="_Adjustments">
                            <MenuItem Header="Brightness / _Contrast…" Click="OnBrightnessContrastClicked"/>
                            <MenuItem Header="_Hue / Saturation…"      Click="OnHueSaturationClicked"/>
                            <MenuItem Header="_Levels…"                Click="OnLevelsClicked"/>
                            <MenuItem Header="C_urves…"                Click="OnCurvesClicked"/>
                            <MenuItem Header="Color _Balance…"         Click="OnColorBalanceClicked"/>
                        </MenuItem>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="Rotate Canvas">
                            <MenuItem Header="90° Clockwise"         Click="OnRotate90CWClicked"/>
                            <MenuItem Header="90° Counter-Clockwise" Click="OnRotate90CCWClicked"/>
                            <MenuItem Header="180°"                  Click="OnRotate180Clicked"/>
                        </MenuItem>
                        <MenuItem Header="Flip Canvas">
                            <MenuItem Header="Flip _Horizontal" Click="OnFlipHClicked"/>
                            <MenuItem Header="Flip _Vertical"   Click="OnFlipVClicked"/>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="_Layer">
                        <MenuItem Header="_New Layer"       Click="OnAddLayerClicked"/>
                        <MenuItem Header="Duplicate Layer"  Click="OnDuplicateLayerClicked"/>
                        <MenuItem Header="Merge Down"       Click="OnMergeDownClicked"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="Delete Layer"     Click="OnDeleteActiveLayerClicked"/>
                    </MenuItem>
                    <MenuItem Header="_View">
                        <MenuItem Header="Zoom _In"    Click="OnZoomInClicked"    InputGesture="Ctrl+OemPlus"/>
                        <MenuItem Header="Zoom _Out"   Click="OnZoomOutClicked"   InputGesture="Ctrl+OemMinus"/>
                        <MenuItem Header="_Reset Zoom" Click="OnZoomResetClicked" InputGesture="Ctrl+D0"/>
                        <Separator Background="#3a3a3a"/>
                        <MenuItem Header="Toggle _Grid" Click="OnToggleGridClicked" InputGesture="Ctrl+G"/>
                    </MenuItem>
                    <MenuItem Header="_Help"/>
                </Menu>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             STATUS BAR
             ═══════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="24"
                Padding="12,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">

                <!-- Left: doc status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="StatusText" Classes="status" Text="Ready"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderBrush}" Margin="12,4"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Classes="status" Text="Dimensions: "/>
                    <TextBlock x:Name="CanvasSizeText" Classes="status" Text="800 × 600" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource BorderBrush}" Margin="12,4"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock x:Name="ColorModeText" Classes="status" Text="RGB / 8-bit" Foreground="{StaticResource TextBrush}"/>
                </StackPanel>

                <Rectangle Grid.Column="5" Width="1" Fill="{StaticResource BorderBrush}" Margin="12,4"/>

                <!-- Right: Zoom -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="status" Text="Zoom:"/>
                    <TextBlock x:Name="StatusZoomText" Classes="status" Text="100%" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             MAIN AREA: Icon Strip | Canvas | Right Panels
             ═══════════════════════════════════════════════════════════ -->
        <Grid ColumnDefinitions="46,*,280">

            <!-- ══ LEFT: ICON TOOL STRIP ═══════════════════════════════ -->
            <views:ToolsPanel Grid.Column="0" x:Name="ToolsPanelControl"/>

            <!-- ══ CENTER: CANVAS ═════════════════════════════════════ -->
            <Grid Grid.Column="1" RowDefinitions="18,*" ColumnDefinitions="18,*">

                <!-- Corner cap -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,1"/>

                <!-- Top ruler -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Canvas x:Name="TopRulerCanvas" Background="Transparent"/>
                </Border>

                <!-- Left ruler -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Canvas x:Name="LeftRulerCanvas" Background="Transparent"/>
                </Border>

                <!-- Canvas viewport -->
                <Border Grid.Row="1" Grid.Column="1" Background="#181818" ClipToBounds="True">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="100">
                            <!-- Checkerboard -->
                            <Border x:Name="CanvasCheckerBg">
                                <Border.Background>
                                    <DrawingBrush TileMode="Tile" SourceRect="0,0,16,16" DestinationRect="0,0,16,16">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing Brush="#1e1e1e">
                                                    <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,16,16"/></GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <GeometryDrawing Brush="#252525">
                                                    <GeometryDrawing.Geometry>
                                                        <GeometryGroup>
                                                            <RectangleGeometry Rect="0,0,8,8"/><RectangleGeometry Rect="8,8,8,8"/>
                                                        </GeometryGroup>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.Background>
                            </Border>

                            <!-- Canvas shadow -->
                            <Border BoxShadow="0 10 40 0 #80000000" CornerRadius="0">
                                <views:CanvasView x:Name="MainCanvasView"/>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ══ RIGHT: PANELS ══════════════════════════════════════ -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- ── (a) COLOR ────────────────────────────────── -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Border Classes="panel-section-header">
                                <TextBlock Classes="panel-title" Text="COLOR"/>
                            </Border>
                            <StackPanel Spacing="8" Margin="16,12">
                                <!-- R -->
                                <Grid ColumnDefinitions="14,*,40">
                                    <TextBlock Grid.Column="0" Text="R" Foreground="#ff5555" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="RedSlider" Minimum="0" Maximum="255" Margin="8,0" ValueChanged="OnRgbSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="RedValue" Text="0" Classes="status" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}"/>
                                </Grid>
                                <!-- G -->
                                <Grid ColumnDefinitions="14,*,40">
                                    <TextBlock Grid.Column="0" Text="G" Foreground="#55ff55" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="GreenSlider" Minimum="0" Maximum="255" Margin="8,0" ValueChanged="OnRgbSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="GreenValue" Text="0" Classes="status" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}"/>
                                </Grid>
                                <!-- B -->
                                <Grid ColumnDefinitions="14,*,40">
                                    <TextBlock Grid.Column="0" Text="B" Foreground="#55aaff" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="BlueSlider" Minimum="0" Maximum="255" Margin="8,0" ValueChanged="OnRgbSliderChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="BlueValue" Text="0" Classes="status" HorizontalAlignment="Right" Foreground="{StaticResource TextBrush}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── (b) ADJUSTMENTS ────────────────────────────── -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Border Classes="panel-section-header">
                                <TextBlock Classes="panel-title" Text="ADJUSTMENTS"/>
                            </Border>
                            <UniformGrid Columns="4" Margin="12">
                                <Button Classes="tb" ToolTip.Tip="Brightness/Contrast" Click="OnBrightnessContrastClicked">
                                    <Path Fill="{StaticResource TextDimBrush}" Data="M10,2 A8,8 0 1,0 10,18 A8,8 0 1,0 10,2 M10,4 V16 A6,6 0 1,1 10,4" Stretch="Uniform" Width="14" Height="14"/>
                                </Button>
                                <Button Classes="tb" ToolTip.Tip="Levels" Click="OnLevelsClicked">
                                    <Path Fill="{StaticResource TextDimBrush}" Data="M2,16 H18 V18 H2 Z M4,14 H6 V10 H4 Z M9,14 H11 V4 H9 Z M14,14 H16 V8 H14 Z" Stretch="Uniform" Width="14" Height="14"/>
                                </Button>
                                <Button Classes="tb" ToolTip.Tip="Curves" Click="OnCurvesClicked">
                                    <Path Fill="{StaticResource TextDimBrush}" Data="M2,18 C2,18 6,14 10,10 C14,6 18,2 18,2" Stroke="{StaticResource TextDimBrush}" StrokeThickness="2" Stretch="Uniform" Width="14" Height="14"/>
                                </Button>
                                <Button Classes="tb" ToolTip.Tip="Hue/Saturation" Click="OnHueSaturationClicked">
                                    <Path Fill="{StaticResource TextDimBrush}" Data="M10,2 L18,10 L10,18 L2,10 Z" Stretch="Uniform" Width="14" Height="14"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- ── (c) LAYERS ─────────────────────────────────── -->
                    <DockPanel Grid.Row="2">
                        <Border DockPanel.Dock="Top" Classes="panel-section-header">
                            <TextBlock Classes="panel-title" Text="LAYERS"/>
                        </Border>
                        
                        <Border DockPanel.Dock="Bottom" Background="{StaticResource HeaderBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="8,4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <Button Classes="tb" ToolTip.Tip="New Layer" Click="OnAddLayerClicked">
                                    <Path Fill="{StaticResource TextDimBrush}" Data="M19,13 H13 V19 H11 V13 H5 V11 H11 V5 H13 V11 H19 V13 Z" Stretch="Uniform" Width="12" Height="12"/>
                                </Button>
                                <Button Classes="tb" ToolTip.Tip="Delete Layer" Click="OnDeleteActiveLayerClicked">
                                    <Path Fill="#ff5555" Data="M6,19 C6,20.1 6.9,21 8,21 H16 C17.1,21 18,20.1 18,19 V7 H6 V19 Z M19,4 H15.5 L14.5,3 H9.5 L8.5,4 H5 V6 H19 V4 Z" Stretch="Uniform" Width="12" Height="12"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LayersStack"/>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
